@inject UIService UIService

@if (_show && _model is not null)
{
	<div class="fixed inset-0 top-0 right-0 bottom-0 left-0 z-30 grid place-items-center">
		<div class="fixed inset-0 top-0 right-0 bottom-0 left-0 bg-black/20"></div>
		<div class="z-40 flex w-[450px] flex-col rounded-lg bg-white p-5 shadow-2xl">
			<div class="flex items-center justify-between">
				<h4 class="text-3xl font-medium">Confirm?</h4>
				<button type="button" class="cursor-pointer rounded border border-slate-200 p-1" @onclick="Close">
					<img src="icons/x.svg" />
				</button>
			</div>
			<hr class="mt-3 mb-5 text-slate-100" />

			<p class="text-lg text-slate-700">@_model!.Message</p>

			<hr class="mt-5 mb-3 text-slate-100" />
			<div class="flex items-center justify-end gap-10">
				<button 
					type="button" class="cursor-pointer rounded border border-green-200 bg-green-50 px-6 py-1 text-green-600 hover:text-green-100" 
					@onclick="HandleYes">Yes</button>
				<button
					type="button" class="cursor-pointer rounded border border-red-50 bg-red-100 px-6 py-1 text-red-600 hover:text-red-100"
					@onclick="HandleNo">No</button>
			</div>
		</div>
	</div>
}
@code {
	private bool _show;
	private ConfirmationModel? _model;

	protected override void OnInitialized()
	{
		UIService.ConfirmationTriggered += HandleConfirmationTriggered;
	}
	private void HandleConfirmationTriggered(ConfirmationModel confirmationModel)
	{
		_model = confirmationModel;
		_show = true;
		InvokeAsync(StateHasChanged);
	}

	private void HandleYes()
	{
		_model!.OnYes.Invoke();
		Close();
	}

	private void HandleNo()
	{
		_model!.OnNo?.Invoke();
		Close();
	}

	private void Close()
	{
		_model = null;
		_show = false;
	}
}
