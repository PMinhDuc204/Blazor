<aside class="flex w-72 flex-col border-r border-slate-200 bg-white">
    <nav class="flex-1 space-y-3 p-3">
        <NavLink href="dashboard" class="flex w-full items-center gap-3 rounded border border-slate-200 px-3 py-2 hover:bg-emerald-100">
            <img src="icons/layout-dashboard.svg" alt="" />
            <span class="font-medium">Dashboard</span>
        </NavLink>

        <NavLink href="invoices" class="flex w-full items-center gap-3 rounded border border-slate-200 px-3 py-2 hover:bg-emerald-100">
            <img src="icons/file-text.svg" alt="" />
            <span class="font-medium">Invoices</span>
        </NavLink>

        <NavLink href="clients" class="flex w-full items-center gap-3 rounded border border-slate-200 px-3 py-2 hover:bg-emerald-100">
            <img src="icons/users-round.svg" alt="" />
            <span class="font-medium">Clients</span>
        </NavLink>

        <NavLink href="services" class="flex w-full items-center gap-3 rounded border border-slate-200 px-3 py-2 hover:bg-emerald-100">
            <img src="icons/boxes.svg" alt="" />
            <span class="font-medium">Products/Services</span>
        </NavLink>
    </nav>

    <div class="border-t border-green-200 p-3">
        <div class="g-emerald-50 flex flex-col items-center justify-center gap-3 rounded p-3">
            <label class="font-medium">
                My Business
            </label>
            <button type="button" class="flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-green-300 bg-green-100 px-3 py-1 hover:bg-green-200" @onclick="() => _showSettingModal = true">
                <img src="icons/settings.svg" alt="" />
                <span>Settings</span>
            </button>
        </div>
    </div>
</aside>

@if(_showSettingModal) {
    <SettingFormModal onClose="() => _showSettingModal = false"/>
}

@code {

    private bool _showSettingModal;

    private void CloseSettingModal()
    {
        _showSettingModal = false;
    }

    private void HandleSave()
    {
        CloseSettingModal();
    }
}