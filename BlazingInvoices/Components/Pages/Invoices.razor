@page "/invoices"

<div class="flex w-full flex-col rounded-lg bg-white p-5">
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-medium text-shadow-slate-800">Invoice Management</h1>
        
        <button class="flex cursor-pointer items-center justify-center gap-2 rounded border border-green-300 bg-green-100 px-3 py-1 hover:bg-green-200">
            <img src="icons/plus.svg" alt=""/>
            <span>Create Invoice</span>
        </button>
    </div>
    <hr class="mt-2 mb-5 w-full text-slate-200" />
    
    <div class="flex w-full items-center border-b text-slate-300">
        @foreach (var tab in _tabs)
        {
            string activeClasses = "";
            if (tab.IsActive)
            {
                activeClasses = $"bg-{tab.ActiveColor}-50 border-b-2 border-{tab.ActiveColor}-600 ext-{tab.ActiveColor}-600";
            }
            <button type="button" class="cursor-pointer px-4 py-2 text-sm font-medium @activeClasses" @onclick="() => ChangeTab(tab)">@tab.Name</button>
        }
    </div>
    <div class="tab-content mt-5">
        @if (!_invoices.Any())
        {
            <div class="m-5 p-5 text-center">
                <p class="text-3xl font-bold text-slate-400">No invoices added yet.</p>
            </div>
        }
        else
        {
            <div class="">
				<table class="min-w-full text-sm">
					<thead>
						<tr class="border-b border-slate-400">
							<th class="py-2 text-left">Invoice Number</th>
							<th class="py-2 text-left">Client</th>
							<th class="py-2 text-left">Issued on</th>
							<th class="py-2 text-left">Due on</th>
                            <th class="py-2 text-left">Status</th>
                            <th class="py-2 text-left">Total Amount</th>
							<th class="py-2">Action</th>
						</tr>
					</thead>
					<tbody>
                        @foreach (var invoice in _invoices)
                        {
                            <tr class="border-b border-slate-400">
							    <td class="py-2 text-left">@invoice.InvoiceNumber</td>
							    <td class="py-2 text-left">@invoice.ClientName</td>
							    <td class="py-2 text-left">@invoice.IssuedOn.ToString("dd-MMM-yyyy")</td>
							    <td class="py-2 text-left">@(invoice.DueOn?.ToString("dd-MMM-yyyy") ?? "NA")</td>
                                <td class="py-2 text-left">
                                    @if(invoice.IsPaid)
                                    {
                                        <label class="rounded-full border border-green-300 bg-green-200 px-3 text-xs text-green-800">Paid</label>
                                    } else
                                    {
                                        <label class="rounded-full border border-amber-300 bg-amber-200 px-3 text-xs text-amber-800">Pending</label>

                                    }
                                </td>
                                <td class="py-2 text-left">@invoice.TotalAmount.ToString("C")</td>
							    <td class="py-2">
                                    <div class="flex items-center gap-1">
                                        <button type="button" class="cursor-pointer px-2 text-blue-500 underline hover:bg-blue-50 hover:text-blue-800">@invoice.LineItems.Count() items</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (_showLineItemsForInvoiceId > 0)
{
    var invoice = _invoices.First(i => i.Id == _showLineItemsForInvoiceId.Value);
    <RightSidePanel Title="@(invoice.InvoiceNumber + "- Line Items")" onClose="() => _showLineItemsForInvoiceId = null">
        <div class="">
		    <table class="min-w-full text-sm">
			    <thead>
				    <tr class="border-b border-slate-400">
					    <th class="py-2 text-left">Invoice Number</th>
					    <th class="py-2 text-left">Client</th>
                        <th class="py-2 text-left">Issued on</th>
					    <th class="py-2 text-left">Due on</th>
                        <th class="py-2 text-left">Status</th>
                        <th class="py-2 text-left">Total Amount</th>
                        <th class="py-2">Action</th>
				    </tr>
				</thead>
            </table>
        </div>
    </RightSidePanel>
}

@code {

    private Tab[] _tabs = [
        new("Recent", "indigo", true),
        new("Pending", "amber"),
        new("Paid", "emerald"),
        new("All", "blue"),
    ];

    private IEnumerable<InvoiceModel> _invoices = [];

    private int? _showLineItemsForInvoiceId;

    protected override void OnInitialized()
    {
        _invoices = InvoiceSeeder.GetInvoiceModels();
    }

    private void ChangeTab(Tab tab)
    {
        var currentActiveTab = _tabs.First(t => t.IsActive);
        currentActiveTab.IsActive = false;
        tab.IsActive = true;
    }

    private class Tab
    {
        public Tab(string name, string activeColor, bool isActive = false) =>
                (Name, ActiveColor, IsActive) = (name, activeColor, isActive);


        public string Name { get; set; }
		public string ActiveColor { get; set; }
		public bool IsActive { get; set; }
    }
}

<div class="hidden">
    <span class="border-indigo-600 bg-indigo-50 text-indigo-600"></span>
    <span class="border-emerald-600 bg-emerald-50 text-emerald-600"></span>
    <span class="border-amber-600 bg-amber-50 text-amber-600"></span>
    <span class="border-blue-600 bg-blue-50 text-blue-600"></span>
</div>