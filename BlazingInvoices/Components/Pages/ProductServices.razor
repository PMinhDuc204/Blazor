@page "/services"

@inject UIService UIService

<div class="flex w-full flex-col rounded-lg bg-white p-5">
	<div class="flex items-center justify-between">
		<h1 class="text-xl font-medium text-slate-800">Product/Services</h1>

		<button type="button" class="flex cursor-pointer items-center justify-center gap-2 border-green-300 bg-green-100 px-3 py-1 hover:bg-green-200" @onclick="AddNewService">
			<img src="icons/plus.svg" alt="" />
			<span>Add Product/Services</span>
		</button>
	</div>
	<hr class="mt-2 mb-5 w-full text-slate-200" />

	<div class="page-content">
		@if (!_services.Any())
		{
			<div class="m-5 p-5 text-center">
				<p class="text-3xl font-bold text-slate-400">No product/services added yet.</p>
			</div>
		}
		else
		{
			<div class="grid grid-cols-2 gap-7">
				@foreach (var service in _services)
				{
					<div class="rounded border border-slate-100 p-3 hover:bg-green-50">
						<div class="flex justify-between gap-3">
							<h2 class="font-medium">@service.Name</h2>
							<div class="flex flex-col items-end">
								<label class="font-medium">@service.Rate.ToString("C")</label>
								<span class="text-sm text-slate-500">@service.Unit</span>
							</div>
						</div>
						<p class="my-2">@service.Description</p>
						<hr class="my-5 w-full text-slate-100" />
						<div class="flex items-center justify-end gap-4">
							<button type="button" class="flex cursor-pointer items-center justify-center gap-1 border-blue-300 bg-blue-100 px-1 text-xs hover:bg-blue-200" @onclick="() => EditService(service)">
								<img src="icons/pencil-line.svg" alt="" />
								<span>Edit</span>
							</button>
							<button type="button" class="flex cursor-pointer items-center justify-center gap-1 border-red-300 bg-red-100 px-1 text-xs hover:bg-red-200">
								<img src="icons/x.svg" alt="" @onclick="() => DeleteService(service)" />
								<span>Delete</span>
							</button>
						</div>
					</div>
				}
			</div>
		}
	</div>
</div>

@if (_showSidebar && _model is not null)
{
	<SaveServiceForm Service="_model" 
					OnSidebarClose="HandleSidebarClosed" />
}

@code {
	private IEnumerable<ServiceModel> _services = [];

	private bool _showSidebar = false;
	private ServiceModel? _model = null;

	protected override void OnInitialized()
	{
		_services = ServiceModel.GetSeedData();
	}

	private void AddNewService()
	{
		_model = new();
		_showSidebar = true;
	}

	private void EditService(ServiceModel service)
	{
		_model = service.Clone();
		_showSidebar = true;
	}

	private void HandleSidebarClosed()
	{
		_model = null;
		_showSidebar = false;
	}

	private void DeleteService(ServiceModel service)
	{
		var confirmationModel = ConfirmationModel.Create($"Do you really want to delete '{service.Name}' service", () =>
		{

		});
		UIService.Confirm(confirmationModel);
	}
}
